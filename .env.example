# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://urluser:secret@postgres:5432/urldb
REDIS_URL=redis://redis:6379
BASE_URL=https://yourdomain.com
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ── Docker Compose ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=secret

# ── CI/CD GitHub Actions Secrets (set in repo settings, not here) ─────────────
# DOCKER_USERNAME=yourdockerhub
# DOCKER_PASSWORD=
# SERVER_HOST=123.456.789.0
# SSH_KEY=
